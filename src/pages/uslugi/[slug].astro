---
import Layout from "../../layouts/Layout.astro";
export const prerender = false;

const { slug } = Astro.params;

const services: Record<string, any> = {
    "holowanie-laweta": {
        title: "Holowanie i laweta",
        short: "Bezpieczny transport każdego pojazdu",
        desc: "Profesjonalne holowanie i transport lawetą...",
        img: "/images/services/laweta.jpg",
        bullets: ["Załadunek najazdowy", "Pojazdy do 7 ton", "Holowanie krajowe i zagraniczne"],
        details: [
            { heading: "Jak działamy?", body: "Po przyjęciu zlecenia nasz kierowca wyjeżdża natychmiast. Docieramy średnio w 15–30 minut na terenie Kalisza i okolic." },
            { heading: "Co holujemy?", body: "Osobówki, busy, vany, motocykle oraz pojazdy ciężarowe do 7 ton. Dysponujemy lawetą standardową i ciężką." },
            { heading: "Ile to kosztuje?", body: "Wycenę podajemy przed przystąpieniem do pracy. Transparentne stawki, zero ukrytych kosztów." },
        ],
    },
    "pomoc-drogowa-24h": {
        title: "Pomoc drogowa 24h",
        short: "Jesteśmy tam, gdzie nas potrzebujesz",
        desc: "Awaria o każdej porze? Docieramy średnio w 15–30 minut.",
        img: "/images/services/pomoc-drogowa.jpg",
        bullets: ["Dojazd 15–30 min", "Bez dopłat w nocy", "Cały rok, 365 dni"],
        details: [
            { heading: "Dyżurujemy całą dobę", body: "Nasi kierowcy są dostępni 24 godziny na dobę, 7 dni w tygodniu, 365 dni w roku." },
            { heading: "Zakres pomocy", body: "Rozruch, wymiana koła, otwarcie pojazdu, dostarczenie paliwa, holowanie do warsztatu." },
            { heading: "Obszar działania", body: "Kalisz, Ostrów Wielkopolski, Jarocin i okoliczne powiaty. Zlecenia ogólnopolskie na zapytanie." },
        ],
    },
    "pomoc-przy-wypadku": {
        title: "Pomoc przy wypadku",
        short: "Szybka reakcja w najtrudniejszych chwilach",
        desc: "Wypadek drogowy to sytuacja kryzysowa. Zabezpieczymy miejsce zdarzenia.",
        img: "/images/services/wypadek.jpg",
        bullets: ["Zabezpieczenie miejsca zdarzenia", "Ewakuacja pojazdu", "Wsparcie z ubezpieczycielem"],
        details: [
            { heading: "Pierwsza reakcja", body: "Zabezpieczamy miejsce wypadku, pomagamy w kontakcie ze służbami i ubezpieczycielem." },
            { heading: "Ewakuacja pojazdu", body: "Bezpieczne zabranie uszkodzonego pojazdu z jezdni lub rowu — nawet przy trudnym dostępie." },
            { heading: "Współpraca z ubezpieczalnią", body: "Obsługujemy zlecenia PZU, Warta, Allianz i wielu innych. Przeprowadzimy Cię przez cały proces." },
        ],
    },
    "uruchomienie-auta-akumulator": {
        title: "Uruchomienie auta",
        short: "Martwy akumulator? Zrestartujemy Cię w minuty",
        desc: "Rozładowany akumulator, zatrzaśnięte kluczyki, brak paliwa.",
        img: "/images/services/akumulator.jpg",
        bullets: ["Rozruch z kabli", "Wymiana akumulatora", "Otwarcie pojazdu bez uszkodzeń"],
        details: [
            { heading: "Rozruch awaryjny", body: "Uruchamiamy pojazd z kabli lub przenośnego boostera. Szybko i bezpiecznie dla elektroniki auta." },
            { heading: "Wymiana akumulatora", body: "Przywozimy i wymieniamy akumulator na miejscu. Szeroki wybór rozmiarów w pojeździe serwisowym." },
            { heading: "Otwarcie pojazdu", body: "Zatrzaśnięte kluczyki? Otwieramy pojazd bez uszkodzeń przy użyciu profesjonalnych narzędzi." },
        ],
    },
};

const service = services[slug as string];
if (!service) return Astro.redirect('/uslugi');
---

<Layout>
        <main class="bg-black min-h-screen" style="font-family:'Barlow Condensed',sans-serif;">
            <div
                    class="relative h-80 md:h-[480px] overflow-hidden flex items-end"
                    style={service.img ? `background-image: url('${service.img}'); background-size: cover; background-position: center;` : ''}
            >
                <div class="absolute inset-0 bg-gradient-to-br from-zinc-900 to-zinc-800 flex items-center justify-center">
                    <span class="text-zinc-700 text-xs uppercase tracking-widest">[ {service.title} ]</span>
                </div>
                <div class="absolute inset-0 bg-gradient-to-t from-black via-black/50 to-transparent"></div>
                <div class="absolute top-0 left-0 right-0 h-1 bg-yellow-400"></div>

                <div class="relative z-10 max-w-7xl mx-auto px-6 md:px-12 lg:px-20 pb-12 w-full">
                    <div class="flex items-center gap-2 text-sm text-zinc-400 mb-3">
                        <a href="/" class="hover:text-yellow-400 transition-colors">Strona główna</a>
                        <span>/</span>
                        <a href="/uslugi" class="hover:text-yellow-400 transition-colors">Usługi</a>
                        <span>/</span>
                        <span class="text-zinc-500">{service.title}</span>
                    </div>
                    <span class="text-yellow-400 text-xs font-bold uppercase tracking-[0.25em]">{service.short}</span>
                    <h1 class="mt-1 text-5xl md:text-6xl font-black text-white leading-tight uppercase">
                        {service.title}
                    </h1>
                    <ul class="flex flex-wrap gap-2 mt-4">
                        {service.bullets.map((b: string) => (
                                <li class="flex items-center gap-1.5 text-xs text-black font-bold bg-yellow-400 px-3 py-1 rounded-full uppercase">
                                    <span class="w-1 h-1 rounded-full bg-black/40 inline-block"></span>
                                    {b}
                                </li>
                        ))}
                    </ul>
                </div>
            </div>


            <div class="max-w-7xl mx-auto px-6 md:px-12 lg:px-20 py-16">
                <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">

                    ->
                    <div class="lg:col-span-2 flex flex-col gap-10">
                        <p class="text-zinc-300 text-lg leading-relaxed">{service.desc}</p>

                        <div class="flex flex-col gap-6">
                            {service.details.map((d: any) => (
                                    <div class="border-l-4 border-yellow-400 bg-zinc-900 rounded-r-xl px-6 py-5">
                                        <h3 class="text-white font-black text-xl uppercase mb-2">{d.heading}</h3>
                                        <p class="text-zinc-400 text-sm leading-relaxed">{d.body}</p>
                                    </div>
                            ))}
                        </div>
                    </div>


                    <div class="flex flex-col gap-4">

                        <div class="bg-yellow-400 rounded-2xl p-6 flex flex-col gap-4">
                            <h3 class="text-black font-black text-xl uppercase">Potrzebujesz tej usługi?</h3>
                            <p class="text-black/70 text-sm font-bold">Zadzwoń teraz — wyślemy pomoc w ciągu 30 minut.</p>

                            <a href="tel:571531112"
                               class="flex items-center justify-center gap-3 bg-black text-white font-black text-sm tracking-widest uppercase px-5 py-3.5 rounded-full transition-all duration-200 hover:-translate-y-0.5"
                            >
                        <span class="relative flex items-center justify-center w-7 h-7 bg-green-500 rounded-full shrink-0">
                <span class="absolute inset-0 rounded-full bg-green-500 animate-ping opacity-50"></span>
                <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 text-white relative z-10 rotate-12" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M6.62 10.79a15.05 15.05 0 0 0 6.59 6.59l2.2-2.2a1 1 0 0 1 1.01-.24c1.12.37 2.33.57 3.58.57a1 1 0 0 1 1 1V20a1 1 0 0 1-1 1C10.61 21 3 13.39 3 4a1 1 0 0 1 1-1h3.5a1 1 0 0 1 1 1c0 1.25.2 2.46.57 3.58a1 1 0 0 1-.24 1.01l-2.21 2.2z"/>
                </svg>
              </span>
                                571 531 112
                            </a>
                        </div>
                        <div class="bg-zinc-900 border border-zinc-800 rounded-2xl p-6 flex flex-col gap-3">
                            <h3 class="text-white font-black text-lg uppercase">Inne usługi</h3>
                            {Object.entries(services).filter(([s]) => s !== slug).map(([s, srv]: [string, any]) => (

                                    <a href={`/uslugi/${s}`}
                                       class="flex items-center gap-2 text-zinc-400 hover:text-yellow-400 text-sm font-bold uppercase tracking-wide transition-colors group"
                                    >
                                        <span class="w-1.5 h-1.5 rounded-full bg-yellow-400 opacity-0 group-hover:opacity-100 transition-opacity shrink-0"></span>
                                        {srv.title}
                                    </a>
                            ))}
                        </div>
                    </div>

                </div>
            </div>

        </main>
</Layout>
