---
const keywords = [
    "Pomoc drogowa Kalisz",
    "Laweta Kalisz",
    "Holowanie 24/7",
    "Awaria na drodze",
    "Transport pojazdu",
    "Pomoc drogowa Ostrów",
    "Laweta całą dobę",
    "Wypadek drogowy",
    "Holowanie za granicą",
    "Assistance OC",
    "Pomoc drogowa A2",
    "Szybki dojazd 15 min",
];
---

<div class="bg-yellow-400 flex justify-center items-center overflow-hidden py-2.5">
    <div class="flex justify-center items-center lg:hidden animate-custom-pulse">
        <span id="mobile-word text-black text-base font-black uppercase tracking-widest">{keywords[0]}</span>
    </div>

    <div class="hidden lg:flex whitespace-nowrap animate-marquee-container">
        <div class="flex animate-marquee">
            {[...keywords, ...keywords].map((kw) => (
                    <span class="inline-flex items-center gap-2 mx-6 text-black text-base font-black uppercase tracking-widest shrink-0">
                    {kw}
                </span>
            ))}
        </div>
    </div>
</div>

<script define:vars={{ keywords }}>
    const wordElement = document.getElementById('mobile-word');
    let currentIndex = 0;

    function updateWord() {
        currentIndex = (currentIndex + 1) % keywords.length;
        if (wordElement) {
            wordElement.textContent = keywords[currentIndex];
        }
    }


    setInterval(updateWord, 4000);
</script>

<style>
    @keyframes marquee {
        0% { transform: translateX(0); }
        100% { transform: translateX(-50%); }
    }
    .animate-marquee {
        animation: marquee 44s linear infinite;
    }
    .animate-marquee-container:hover .animate-marquee {
        animation-play-state: paused;
    }

    @keyframes pulse-with-scale {
        0%, 100% { opacity: 1; transform: scale(1); }
        50% { opacity: 0; transform: scale(0.95); } /* Schodzimy do 0, żeby podmiana słowa była płynna */
    }

    .animate-custom-pulse {
        animation: pulse-with-scale 2s ease-in-out infinite;
    }
</style>