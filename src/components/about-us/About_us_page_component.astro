---
// src/pages/o-nas.astro


import Footer_section from "../shared/footer_component/footer_section.astro";
import Navigation_component from "../shared/navigation_component/navigation_component.astro";
const stats = [
    { value: "8+", label: "Lat doświadczenia" },
    { value: "5000+", label: "Zrealizowanych zleceń" },
    { value: "30 min", label: "Średni czas dojazdu" },
    { value: "24/7", label: "Dostępność" },
];

const values = [
    {
        icon: `<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>`,
        title: "Bezpieczeństwo przede wszystkim",
        desc: "Każde zlecenie realizujemy z najwyższą starannością. Twój pojazd jest u nas bezpieczny od momentu odbioru aż do miejsca docelowego.",
    },
    {
        icon: `<circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>`,
        title: "Błyskawiczny czas reakcji",
        desc: "Docieramy na miejsce średnio w 15–30 minut. Działamy całą dobę, 365 dni w roku — bez wyjątków.",
    },
    {
        icon: `<path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>`,
        title: "Uczciwe podejście",
        desc: "Transparentne ceny, zero ukrytych kosztów. Wycenę otrzymujesz przed przystąpieniem do pracy — zawsze.",
    },
    {
        icon: `<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>`,
        title: "Obsługa ubezpieczycieli",
        desc: "Współpracujemy z PZU, Wartą, Allianz i innymi. Przejmiemy całą komunikację z ubezpieczycielem za Ciebie.",
    },
];

const fleet = [
    {
        name: "Laweta standard",
        desc: "Transport osobówek i małych aut dostawczych. Załadunek najazdowy, platforma aluminiowa.",
        capacity: "Do 3,5 t",
        img: "/images/fleet/laweta-standard.jpg",
    },
    {
        name: "Laweta ciężka",
        desc: "Transport busów, vanów i pojazdów ciężarowych. Zwiększony udźwig i wzmocniona platforma.",
        capacity: "Do 7 t",
        img: "/images/fleet/laweta-ciezka.jpg",
    },
    {
        name: "Pojazd serwisowy",
        desc: "Szybka pomoc na miejscu — rozruch, wymiana koła, otwarcie pojazdu, paliwo.",
        capacity: "Pomoc mobilna",
        img: "/images/fleet/serwis.jpg",
    },
];

const timeline = [
    { year: "2016", title: "Założenie firmy", desc: "Michalak24 startuje jako jednoosobowa działalność z jedną lawetą na terenie Kalisza." },
    { year: "2018", title: "Pierwsza rozbudowa floty", desc: "Dołącza druga laweta i pojazd serwisowy. Zasięg rozszerza się na powiat kaliski." },
    { year: "2020", title: "Współpraca z ubezpieczalniami", desc: "Podpisanie umów z PZU i Wartą. Setki zleceń assistance rocznie." },
    { year: "2022", title: "Ekspansja regionalna", desc: "Obsługujemy Kalisz, Ostrów Wielkopolski, Jarocin i okolice. Nowa siedziba i parking." },
    { year: "2024", title: "Dziś", desc: "Ponad 5000 zrealizowanych zleceń, 3 pojazdy w flocie i zaufanie tysięcy klientów." },
];

const areas = ["Kalisz", "Ostrów Wielkopolski", "Jarocin", "Pleszew", "Kępno", "Turek", "Konin", "Łódź", "Poznań", "Autostrada A2"];
---

    <main class="bg-black min-h-screen" style="font-family:'Barlow Condensed',sans-serif;">
        <Navigation_component />
        <div class="relative h-72 md:h-96 overflow-hidden flex items-end">
            <div class="absolute inset-0 bg-zinc-900">
                <!-- placeholder: podmień na własne zdjęcie -->
                <div class="w-full h-full bg-gradient-to-br from-zinc-900 to-zinc-800 flex items-center justify-center">
                    <span class="text-zinc-700 text-sm uppercase tracking-widest">[ Twoje zdjęcie tła ]</span>
                </div>
            </div>
            <div class="absolute inset-0 bg-gradient-to-t from-black via-black/50 to-transparent"></div>
            <div class="absolute top-0 left-0 right-0 h-1 bg-yellow-400"></div>

            <div class="relative z-10 max-w-7xl mx-auto px-6 md:px-12 lg:px-20 pb-12 w-full">
                <div class="flex items-center gap-2 text-sm text-zinc-400 mb-3">
                    <a href="/" class="hover:text-yellow-400 transition-colors">Strona główna</a>
                    <span>/</span>
                    <span class="text-zinc-500">O nas</span>
                </div>
                <span class="text-yellow-400 text-xs font-bold uppercase tracking-[0.25em]">Kim jesteśmy</span>
                <h1 class="mt-1 text-5xl md:text-6xl font-black text-white leading-tight uppercase">
                    O firmie <span class="text-yellow-400">Michalak24</span>
                </h1>
            </div>
        </div>

        <!-- STATS -->
        <div class="bg-yellow-400">
            <div class="max-w-7xl mx-auto px-6 md:px-12 lg:px-20 grid grid-cols-2 lg:grid-cols-4">
                {stats.map((s, i) => (
                        <div class={`py-6 px-4 text-center ${i < stats.length - 1 ? 'border-r border-yellow-500' : ''}`}>
                            <p class="text-4xl font-black text-black leading-none">{s.value}</p>
                            <p class="mt-1 text-xs font-bold uppercase tracking-widest text-black/60">{s.label}</p>
                        </div>
                ))}
            </div>
        </div>

        <!-- HISTORIA + ZDJĘCIE -->
        <div class="max-w-7xl mx-auto px-6 md:px-12 lg:px-20 py-20">
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">

                <!-- Zdjęcie placeholder -->
                <div class="relative rounded-2xl overflow-hidden h-96 bg-zinc-900 flex items-center justify-center">
                    <div class="absolute inset-y-0 left-0 w-1 bg-yellow-400"></div>
                    <span class="text-zinc-700 text-sm uppercase tracking-widest">[ Twoje zdjęcie ]</span>
                    <div class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-black/60 to-transparent h-32"></div>
                </div>

                <!-- Tekst -->
                <div class="flex flex-col gap-6">
                    <div>
                        <span class="text-yellow-400 text-xs font-bold uppercase tracking-[0.25em]">Nasza historia</span>
                        <h2 class="mt-2 text-4xl md:text-5xl font-black text-white leading-tight uppercase">
                            Ponad 8 lat<br/>na drodze
                        </h2>
                    </div>
                    <p class="text-zinc-300 text-base leading-relaxed">
                        Michalak24 powstało w 2016 roku z prostej potrzeby — zapewnienia mieszkańcom Kalisza i okolic szybkiej, rzetelnej i uczciwej pomocy drogowej. Zaczynaliśmy od jednej lawety i jednej zasady: <strong class="text-yellow-400">być tam, gdzie nas potrzebują, tak szybko jak to możliwe.</strong>
                    </p>
                    <p class="text-zinc-300 text-base leading-relaxed">
                        Przez lata rozbudowaliśmy flotę, nawiązaliśmy współpracę z największymi ubezpieczycielami w Polsce i rozszerzyliśmy zasięg na cały region. Dziś jesteśmy zaufanym partnerem tysięcy kierowców.
                    </p>
                    <div class="border-l-4 border-yellow-400 bg-zinc-900 rounded-r-xl px-6 py-4">
                        <p class="text-white font-black text-lg uppercase">Ponad 5000 zrealizowanych zleceń i ani jedno nieodebrane wezwanie.</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- WARTOŚCI -->
        <div class="border-t border-zinc-800 py-20 px-6 md:px-12 lg:px-20 bg-zinc-950">
            <div class="max-w-7xl mx-auto">
                <span class="text-yellow-400 text-xs font-bold uppercase tracking-[0.25em]">Czym się kierujemy</span>
                <h2 class="mt-2 text-4xl font-black text-white uppercase mb-12">Nasze wartości</h2>

                <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
                    {values.map((v) => (
                            <div class="bg-zinc-900 border border-zinc-800 hover:border-yellow-400/50 rounded-2xl p-6 flex flex-col gap-4 hover:-translate-y-1 transition-all duration-300">
                                <div class="w-12 h-12 bg-yellow-400/10 rounded-xl flex items-center justify-center">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-yellow-400" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={`<svg>${v.icon}</svg>`} viewBox="0 0 24 24">
                                        <Fragment set:html={v.icon} />
                                    </svg>
                                </div>
                                <h3 class="text-white font-black text-lg uppercase leading-tight">{v.title}</h3>
                                <p class="text-zinc-400 text-sm leading-relaxed">{v.desc}</p>
                            </div>
                    ))}
                </div>
            </div>
        </div>
        <div class="border-t border-zinc-800 py-20 px-6 md:px-12 lg:px-20">
            <div class="max-w-7xl mx-auto">
                <span class="text-yellow-400 text-xs font-bold uppercase tracking-[0.25em]">Czym jeździmy</span>
                <h2 class="mt-2 text-4xl font-black text-white uppercase mb-12">Nasza flota</h2>

                <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                    {fleet.map((vehicle) => (
                            <div class="group bg-zinc-900 border border-zinc-800 hover:border-yellow-400/50 rounded-2xl overflow-hidden transition-all duration-300 hover:-translate-y-1">
                                <!-- placeholder zdjęcie -->
                                <div class="h-48 bg-zinc-800 flex items-center justify-center relative overflow-hidden">
                                    <span class="text-zinc-600 text-xs uppercase tracking-widest">[ {vehicle.name} ]</span>
                                    <div class="absolute bottom-0 left-0 right-0 h-1 bg-yellow-400 scale-x-0 group-hover:scale-x-100 transition-transform duration-300 origin-left"></div>
                                </div>
                                <div class="p-6 flex flex-col gap-3">
                                    <div class="flex items-start justify-between gap-2">
                                        <h3 class="text-white font-black text-xl uppercase">{vehicle.name}</h3>
                                        <span class="text-xs font-bold bg-yellow-400 text-black px-3 py-1 rounded-full shrink-0">{vehicle.capacity}</span>
                                    </div>
                                    <p class="text-zinc-400 text-sm leading-relaxed">{vehicle.desc}</p>
                                </div>
                            </div>
                    ))}
                </div>
            </div>
        </div>
        <div class="border-t border-zinc-800 py-20 px-6 md:px-12 lg:px-20 bg-zinc-950">
            <div class="max-w-7xl mx-auto">
                <div class="grid grid-cols-1 gap-16 items-center">
                    <div class="flex flex-col gap-6">
                        <div>
                            <span class="text-yellow-400 text-xs font-bold uppercase tracking-[0.25em]">Gdzie działamy</span>
                            <h2 class="mt-2 text-4xl font-black text-white uppercase leading-tight">
                                Kalisz i cały<br/><span class="text-yellow-400">region</span>
                            </h2>
                        </div>
                        <p class="text-zinc-300 text-base leading-relaxed">
                            Nasz zasięg obejmuje Kalisz i okoliczne powiaty, ale realizujemy też zlecenia dalekodystansowe na terenie całej Polski i za granicą. Jeśli potrzebujesz pomocy — zadzwoń, dotrzemy.
                        </p>
                        <div class="flex flex-wrap gap-2">
                            {areas.map(area => (
                                    <span class="flex items-center gap-1.5 text-sm font-bold text-black bg-yellow-400 px-3 py-1.5 rounded-full uppercase tracking-wide">
                  <span class="w-1.5 h-1.5 rounded-full bg-black/30 inline-block"></span>
                                        {area}
                </span>
                            ))}
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <Footer_section />

    </main>
